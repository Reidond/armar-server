{
  // ---- Interpreter (uv-managed venv) ----
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // ---- Type checking: basedpyright only (disable Pylance to avoid double errors) ----
  // basedpyright reads config from [tool.basedpyright] in pyproject.toml.
  "python.languageServer": "None",
  "basedpyright.analysis.typeCheckingMode": "standard",

  // ---- Linting + formatting: Ruff ----
  "ruff.importStrategy": "fromEnvironment",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ---- Testing: pytest (offline; no network/containers) ----
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],

  // ---- TOML ----
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // ---- QML: qmlls language server (Qt Qml extension, theqtcompany.qt-qml) ----
  // Use the qmlls shipped in the uv venv's PySide6 so the editor matches
  // scripts/qmllint.sh. pyside6-qmlls already resolves PySide6's bundled Qt
  // modules; we only add the system org.kde.kirigami import path. Diagnostics
  // (incl. inline `// qmllint disable` directives) come from .qmllint.ini.
  "qt-qml.qmlls.customExePath": "${workspaceFolder}/.venv/bin/pyside6-qmlls",
  "qt-qml.qmlls.useNoCMakeCalls": true,
  "qt-qml.qmlls.additionalImportPaths": [
    // Fedora; on Debian/Ubuntu use /usr/lib/<triplet>/qt6/qml instead.
    "/usr/lib64/qt6/qml"
  ],

  // ---- Workspace hygiene ----
  "python.analysis.autoImportCompletions": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.egg-info": true,
    ".pytest_cache": true,
    ".ruff_cache": true
  },
  "cursorpyright.analysis.autoImportCompletions": true
}
