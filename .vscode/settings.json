{
  // ---- Interpreter (uv-managed venv) ----
  "python.defaultInterpreterPath": "${workspaceFolder}/.venv/bin/python",

  // ---- Type checking: basedpyright only (disable Pylance to avoid double errors) ----
  // basedpyright reads config from [tool.basedpyright] in pyproject.toml.
  "python.languageServer": "None",
  "basedpyright.analysis.typeCheckingMode": "standard",

  // ---- Linting + formatting: Ruff ----
  "ruff.importStrategy": "fromEnvironment",
  "[python]": {
    "editor.defaultFormatter": "charliermarsh.ruff",
    "editor.formatOnSave": true,
    "editor.codeActionsOnSave": {
      "source.fixAll.ruff": "explicit",
      "source.organizeImports.ruff": "explicit"
    }
  },

  // ---- Testing: pytest (offline; no network/containers) ----
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,
  "python.testing.pytestArgs": ["tests"],

  // ---- TOML ----
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },

  // ---- Workspace hygiene ----
  "python.analysis.autoImportCompletions": true,
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.egg-info": true,
    ".pytest_cache": true,
    ".ruff_cache": true
  },
  "cursorpyright.analysis.autoImportCompletions": true
}
